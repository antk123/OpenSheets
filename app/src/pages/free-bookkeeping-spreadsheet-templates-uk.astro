---
import Layout from '@/layouts/Layout.astro';
import TemplateCard from '@/components/TemplateCard.astro';
import { templates } from '@/data/templates';
import { siteUrl } from '@/lib/utils';

const title = 'Free Bookkeeping Spreadsheet Templates for UK Small Businesses';
const description = 'Download free Excel bookkeeping templates designed for UK sole traders, landlords, and small businesses. Cash books, P&L, VAT returns, mileage logs — all HMRC-ready.';
const canonical = '/free-bookkeeping-spreadsheet-templates-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${siteUrl}${canonical}`,
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: templates.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteUrl}/templates/${t.id}`,
      name: t.name,
    })),
  },
};

const structuredData = {
  ...jsonLd,
  '@graph': [
    jsonLd,
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Are these bookkeeping templates really free?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. Every template on Open Sheets is free to download with no email required, no sign-up, and no trial period.' },
        },
        {
          '@type': 'Question',
          name: 'Will these work in Google Sheets?',
          acceptedAnswer: { '@type': 'Answer', text: 'Yes. All templates use standard Excel functions fully compatible with Google Sheets. Upload the .xlsx to Google Drive and open in Sheets.' },
        },
      ],
    },
  ],
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={structuredData}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Free Download — No Email Required
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Free Bookkeeping Spreadsheet Templates <span class="text-sky-700">for UK Small Businesses</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Professional Excel templates designed specifically for UK tax rules. Cash books, P&L statements, VAT returns, mileage logs, and more — all free, all HMRC-ready.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-3">Every Template You Need</h2>
        <p class="text-slate-600">Download instantly. No signup. No catch.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {templates.map((template) => (
          <TemplateCard template={template} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Why Use Spreadsheet Templates?</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-sky-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-sky-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">£0 Cost</h3>
            <p class="text-sm text-slate-600">No monthly subscription. No hidden fees. Save £180-£480/year compared to cloud accounting software.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-sky-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-sky-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">HMRC-Ready Categories</h3>
            <p class="text-sm text-slate-600">Built using HMRC's standard expense categories. Your Self Assessment practically fills itself out.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-sky-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-sky-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">You Own Your Data</h3>
            <p class="text-sm text-slate-600">No cloud servers. No data mining. Your financial records stay on your computer where they belong.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-lg bg-sky-100 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-sky-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.902 59.902 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Learn Your Numbers</h3>
            <p class="text-sm text-slate-600">Spreadsheets show you how calculations work. Understanding your finances makes you a better business owner.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">How It Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-sky-700 text-white flex items-center justify-center mx-auto mb-4 text-lg font-bold">1</div>
          <h3 class="font-semibold text-slate-900 mb-2">Download</h3>
          <p class="text-sm text-slate-600">Pick a template and download the .xlsx file instantly. No email gate, no signup.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-sky-700 text-white flex items-center justify-center mx-auto mb-4 text-lg font-bold">2</div>
          <h3 class="font-semibold text-slate-900 mb-2">Fill In</h3>
          <p class="text-sm text-slate-600">Only the blue cells need your input. Everything else calculates automatically.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 rounded-full bg-sky-700 text-white flex items-center justify-center mx-auto mb-4 text-lg font-bold">3</div>
          <h3 class="font-semibold text-slate-900 mb-2">Submit</h3>
          <p class="text-sm text-slate-600">Use the auto-summarised figures for your Self Assessment, VAT return, or MTD quarterly update.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Start for Free Today</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Join thousands of UK small business owners who've ditched expensive software for simple, powerful spreadsheets.</p>
      <a href="/templates" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Browse All Templates
        <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>
</Layout>
