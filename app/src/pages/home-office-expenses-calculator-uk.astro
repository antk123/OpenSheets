---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Home Office Expenses Calculator UK — Working From Home Tax Relief';
const description = 'Free UK home office expenses calculator. Claim working from home tax relief using HMRC flat rate (£6/week) or actual cost method. No signup.';
const canonical = '/home-office-expenses-calculator-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Tax Relief
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Home Office Expenses Calculator <span class="text-sky-700">(Free UK Tool)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Calculate your working from home tax relief. Use HMRC's simplified flat rate or claim actual costs. Free calculator, no signup.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Working From Home Tax Relief</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            If you work from home, HMRC allows you to claim a portion of your household costs as business expenses. This reduces your taxable profit and saves you tax.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            You have two options: the simplified flat rate method (easiest) or the actual cost method (potentially more generous).
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Option 1: Simplified Flat Rate</h3>
          <p class="text-slate-600 mb-4">
            HMRC lets you claim <strong>£6 per week</strong> (£312 per year) without keeping any receipts or calculating proportions. This covers gas, electricity, water, and broadband.
          </p>
          <div class="bg-emerald-50 rounded-lg p-4 border border-emerald-200 mb-6">
            <p class="text-emerald-800 text-sm font-medium">💡 For a basic-rate taxpayer, £312/year saves you £62.40 in tax. For a higher-rate taxpayer, it saves £124.80.</p>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">Option 2: Actual Costs</h3>
          <p class="text-slate-600 mb-4">
            Calculate the actual proportion of household costs used for business. This can be more generous if you have high utility bills or a large home office.
          </p>
          <p class="text-slate-600 mb-4">
            <strong>How to calculate:</strong> Divide your home office area by total home area, then apply that percentage to your household bills.
          </p>
          <p class="text-slate-600 text-sm">
            <strong>Example:</strong> Your office is 10% of your home. Your annual bills are £2,400 gas/electric + £600 broadband = £3,000. Your claim is £3,000 × 10% = £300. Plus you can claim a portion of council tax, insurance, and repairs.
          </p>
        </div>
        <div class="bg-sky-50 rounded-xl p-6 border border-sky-200">
          <h3 class="font-bold text-sky-900 mb-4">Get the Home Office Calculator</h3>
          <p class="text-sm text-sky-800 mb-4">Compare flat rate vs actual costs and see which saves you more tax.</p>
          <a href="/templates/home-office" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Home Office Calculator
          </a>
          <p class="text-xs text-sky-600 text-center">Free. No email required.</p>
          <div class="mt-6 pt-6 border-t border-sky-200">
            <h4 class="font-semibold text-sky-900 text-sm mb-2">What You Can Claim</h4>
            <ul class="text-sm text-sky-800 space-y-1">
              <li>✅ Gas and electricity</li>
              <li>✅ Broadband and phone</li>
              <li>✅ Council tax (proportion)</li>
              <li>✅ Home insurance (proportion)</li>
              <li>✅ Repairs and maintenance</li>
              <li>✅ Rent (if you rent your home)</li>
              <li>❌ Mortgage capital repayments</li>
              <li>❌ Costs for personal use only</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">Flat Rate vs Actual Costs: Which Is Better?</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-bold text-slate-900 mb-3">Choose Flat Rate If...</h3>
          <ul class="space-y-2 text-sm text-slate-600">
            <li>• You want zero paperwork</li>
            <li>• Your bills are relatively low</li>
            <li>• You work from home part-time</li>
            <li>• You don't have a dedicated office room</li>
            <li>• You prefer simplicity over maximising claims</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-bold text-slate-900 mb-3">Choose Actual Costs If...</h3>
          <ul class="space-y-2 text-sm text-slate-600">
            <li>• You have high utility bills</li>
            <li>• You work from home full-time</li>
            <li>• You have a dedicated office room</li>
            <li>• You're a higher-rate taxpayer</li>
            <li>• You're happy to keep records</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Calculate Your Home Office Tax Relief</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">See whether flat rate or actual costs saves you more. Free calculator, instant results.</p>
      <a href="/templates/home-office" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Calculator
      </a>
    </div>
  </section>
</Layout>
