---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Cash Flow Forecast Template UK — Free Excel 12-Month Cash Flow Projection';
const description = 'Free UK cash flow forecast template for small businesses. Project 12 months of income and expenses, spot shortfalls early, and plan ahead. Works in Excel and Google Sheets.';
const canonical = '/cash-flow-forecast-template-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Essential Bookkeeping
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Cash Flow Forecast Template UK <span class="text-sky-700">(Free Download)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Free 12-month cash flow forecast template for UK small businesses. Project income and expenses, spot shortfalls before they happen, and make confident decisions.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Cash Is King — Forecast It</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Profit and cash are not the same thing. You can be profitable on paper and still run out of money. A cash flow forecast shows you when cash will be tight — before it happens.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Our 12-month template breaks down cash in (sales, loans, investments) and cash out (rent, wages, suppliers, tax). It flags months where outgoings exceed income, so you can plan ahead.
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">What Our Template Includes</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>12-month projection:</strong> Month-by-month cash flow</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Cash in categories:</strong> Sales, loans, investments, grants</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Cash out categories:</strong> Rent, wages, suppliers, tax, loan repayments</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Opening/closing balance:</strong> Running total each month</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Shortfall alerts:</strong> Highlights negative months</li>
          </ul>
        </div>
        <div class="bg-emerald-50 rounded-xl p-6 border border-emerald-200">
          <h3 class="font-bold text-emerald-900 mb-4">Get the Cash Flow Forecast</h3>
          <p class="text-sm text-emerald-800 mb-4">Project 12 months of cash flow. Spot problems before they become crises.</p>
          <a href="/templates/cash-flow" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Cash Flow Forecast
          </a>
          <p class="text-xs text-emerald-600 text-center">Free. No email required.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Download Your Free Cash Flow Forecast</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Know your cash position 12 months ahead. Plan with confidence.</p>
      <a href="/templates/cash-flow" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Template
      </a>
    </div>
  </section>
</Layout>
