---
import Layout from '@/layouts/Layout.astro';
import TemplateCard from '@/components/TemplateCard.astro';
import FaqAccordion from '@/components/FaqAccordion.astro';
import { getPopularTemplates } from '@/data/templates';
import { getCollection } from 'astro:content';
import { siteDescription } from '@/lib/utils';

const popularTemplates = getPopularTemplates();
const featuredGuides = (await getCollection('guides')).slice(0, 4);

const categoryCards = [
  {
    title: 'Core Bookkeeping',
    count: 5,
    desc: 'Cash books, expense tracking, and bank reconciliation',
    icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25',
  },
  {
    title: 'Tax & VAT',
    count: 3,
    desc: 'VAT returns, mileage logs, and home office claims',
    icon: 'M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V9zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V9zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V9zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V9zm0 2.25h.008v.008h-.008v-.008zM21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Financial Reports',
    count: 3,
    desc: 'Profit & Loss, Balance Sheet, and Budget Forecast',
    icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
  },
  {
    title: 'Landlord & Property',
    count: 2,
    desc: 'Rental income, property expenses, MTD quarterly updates',
    icon: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  },
];

const whyItems = [
  {
    title: 'No Monthly Subscription',
    desc: 'Save £15-£40 every month. Our templates are completely free. Excel or Google Sheets is all you need.',
    icon: 'M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'You Own Your Data',
    desc: 'Your financial data stays on your computer. No cloud servers, no risk of service shutdowns, no privacy concerns.',
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
  },
  {
    title: 'Built for UK Tax',
    desc: 'Unlike generic templates, ours use HMRC expense categories, UK VAT calculations, mileage rates, and SA103/SA105 box numbers.',
    icon: 'M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Learn as You Go',
    desc: 'Spreadsheets show you how the calculations work. Understanding your numbers makes you a better business owner.',
    icon: 'M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.902 59.902 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5',
  },
];

const faqs = [
  { question: 'Are these templates really free?', answer: 'Yes. Every spreadsheet on this site is free to download with no email required, no sign-up, and no trial period. Just click and download.' },
  { question: 'Will these work in Google Sheets?', answer: 'Yes. All templates use standard Excel functions that are fully compatible with Google Sheets. Upload the .xlsx file to Google Drive and open it in Sheets. Minor formatting differences may appear, but all formulas work correctly.' },
  { question: 'Do I need to know Excel to use these?', answer: 'Basic familiarity with spreadsheets helps, but you do not need to be an expert. Our templates come with instructions on the cover sheet, and only the blue-coloured cells need your input. Everything else calculates automatically.' },
  { question: 'Are these suitable for limited companies?', answer: 'Some templates work well for limited companies (Balance Sheet, Cash Book, VAT Return), but limited companies have more complex reporting requirements than sole traders. Our templates are primarily designed for sole traders, freelancers, and landlords.' },
  { question: 'What is Making Tax Digital (MTD)?', answer: 'MTD is HMRC\'s programme to move tax online. If you are VAT-registered, it already applies to you. For Income Tax, it starts April 2026 if your business or property income is over £50,000. Our guides explain everything you need to know.' },
  { question: 'Can I share these templates with my clients or friends?', answer: 'Yes. Feel free to share the templates. We would appreciate it if you shared a link to our site rather than the file directly, so others can discover the full range of templates and guides.' },
];

const orgSchema = {
  '@type': 'Organization',
  name: 'Open Sheets',
  url: 'https://opensheets.co.uk',
  logo: 'https://opensheets.co.uk/favicon.svg',
  description: siteDescription,
};

const homeFaqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
};
---

<Layout
  title="Open Sheets — Free UK Bookkeeping Spreadsheet Templates"
  description={siteDescription}
  jsonLd={[orgSchema, homeFaqSchema]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-[url('/images/hero-bg.svg')] bg-cover bg-center bg-no-repeat border-b border-slate-200">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-sky-700 animate-pulse" />
          16 Free UK Bookkeeping Spreadsheets + 8 Guides
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-tight mb-6">
          Free Bookkeeping<br />
          <span class="text-sky-700">Spreadsheets & Guides</span>
        </h1>
        <p class="text-lg sm:text-xl text-slate-500 leading-relaxed mb-8 max-w-xl">
          Free, professional Excel spreadsheets and plain-English guides designed for UK small business owners, sole traders, and landlords. No subscriptions. No jargon.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/templates"
            class="inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white h-12 px-8 text-base font-semibold rounded-lg transition-colors"
          >
            Browse Templates
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="/guides"
            class="inline-flex items-center justify-center bg-white hover:bg-slate-50 text-slate-700 border border-slate-200 h-12 px-8 text-base rounded-lg transition-colors"
          >
            Read the Guides
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div><p class="text-3xl font-bold text-slate-900">16</p><p class="text-sm text-slate-500">Free Templates</p></div>
        <div><p class="text-3xl font-bold text-slate-900">8</p><p class="text-sm text-slate-500">In-Depth Guides</p></div>
        <div><p class="text-3xl font-bold text-slate-900">0</p><p class="text-sm text-slate-500">Cost to You</p></div>
        <div><p class="text-3xl font-bold text-slate-900">100%</p><p class="text-sm text-slate-500">Open & Free</p></div>
      </div>
    </div>
  </section>

  <!-- Audience -->
  <section class="py-12 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm font-medium text-slate-500 uppercase tracking-wider mb-4">Built For</p>
      <div class="flex flex-wrap justify-center gap-3">
        {['Sole Traders', 'Self-Employed', 'Landlords', 'Freelancers', 'Small Businesses', 'Startups', 'Contractors'].map((tag) => (
          <span class="inline-flex items-center gap-1.5 bg-white border border-slate-200 text-slate-700 px-4 py-2 rounded-full text-sm font-medium">
            <svg class="w-4 h-4 text-sky-700" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Templates -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Most Popular Templates</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          These are the spreadsheets our community downloads most. Start with one of these and take control of your business finances today.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {popularTemplates.map((template) => (
          <TemplateCard template={template} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/templates" class="inline-flex items-center justify-center border border-slate-300 text-slate-700 hover:bg-slate-100 h-11 px-8 rounded-lg text-sm font-medium transition-colors">
          View All 16 Templates
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Guides -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-sky-100 text-sky-700 mb-4">Free Guides</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Learn the Essentials</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Our jargon-free guides cover everything UK business owners need to know about bookkeeping, tax, and staying compliant.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredGuides.map((guide) => (
          <a
            href={`/guides/${guide.slug}`}
            class="group bg-white rounded-xl p-6 border border-slate-200 text-left hover:shadow-lg hover:border-sky-200 transition-all"
          >
            <div class="flex items-start justify-between mb-3">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-sky-100 text-sky-700">
                {guide.data.category}
              </span>
              <span class="text-xs text-slate-500">{guide.data.readTime}</span>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-sky-700 transition-colors leading-snug">
              {guide.data.title}
            </h3>
            <p class="text-sm text-slate-500 leading-relaxed">{guide.data.description}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/guides" class="inline-flex items-center justify-center border border-slate-300 text-slate-700 hover:bg-white h-11 px-8 rounded-lg text-sm font-medium transition-colors bg-slate-50">
          View All 8 Guides
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Spreadsheets -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">
            Why Simple Spreadsheets<br />Beat Complex Software
          </h2>
          <div class="space-y-6">
            {whyItems.map((item) => (
              <div class="flex gap-4">
                <div class="w-12 h-12 rounded-xl bg-sky-50 flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-sky-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-slate-900 mb-1">{item.title}</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative">
          <div class="bg-slate-100 rounded-2xl p-8 border border-slate-200">
            <div class="grid grid-cols-2 gap-4">
              {[
                { label: 'Templates', count: '16', icon: '📊' },
                { label: 'Guides', count: '8', icon: '📖' },
                { label: 'Formulas', count: '1,800+', icon: '🔢' },
                { label: 'HMRC Categories', count: 'All', icon: '✅' },
              ].map((stat) => (
                <div class="bg-white rounded-xl p-5 text-center border border-slate-200">
                  <p class="text-3xl mb-1">{stat.icon}</p>
                  <p class="text-2xl font-bold text-slate-900">{stat.count}</p>
                  <p class="text-xs text-slate-500 mt-1">{stat.label}</p>
                </div>
              ))}
            </div>
            <div class="mt-6 bg-sky-700 rounded-xl p-5 text-white text-center">
              <p class="text-sm font-medium text-sky-100">Total Value</p>
              <p class="text-3xl font-bold">£0.00</p>
              <p class="text-xs text-sky-100 mt-1">Everything here is completely free</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">Templates for Every Need</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Whether you are just starting out or managing multiple properties, we have a spreadsheet for you.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        {categoryCards.map((cat) => (
          <a href="/templates" class="group bg-white rounded-xl p-6 border border-slate-200 hover:shadow-lg hover:border-sky-200 transition-all text-left">
            <div class="mb-4 text-sky-700">
              <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-slate-900 mb-1 group-hover:text-sky-700 transition-colors">{cat.title}</h3>
            <p class="text-sm text-slate-500 mb-3">{cat.desc}</p>
            <span class="text-xs font-medium text-sky-700">{cat.count} templates &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Landlord + MTD -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="bg-amber-50 rounded-2xl p-8 border border-amber-200">
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-amber-100 text-amber-700 mb-4">For Landlords</span>
            <h2 class="text-3xl font-bold text-slate-900 mb-4">Rental Property Tracking Made Simple</h2>
            <p class="text-slate-600 leading-relaxed mb-6">
              Managing rental properties comes with unique financial complexities. Our property tracker is built specifically for UK landlords with HMRC SA105 categories built in.
            </p>
            <ul class="space-y-3 mb-8">
              {[
                'Track up to 5 properties in one workbook',
                'Mortgage interest tax relief calculated at 20%',
                'Section 24 restrictions built in automatically',
                'Annual summary ready for your tax return',
                'MTD quarterly update template available',
              ].map((item) => (
                <li class="flex items-center gap-3 text-sm text-slate-600">
                  <svg class="w-5 h-5 text-sky-700 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <div class="flex flex-col sm:flex-row gap-3">
              <a href="/templates/rental-property" class="inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                Get the Property Tracker
              </a>
              <a href="/guides/landlord-tax-guide" class="inline-flex items-center justify-center border border-amber-300 text-amber-700 hover:bg-amber-50 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
                Read the Landlord Guide
              </a>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <div class="bg-slate-900 rounded-2xl p-8 text-white">
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-blue-500/20 text-blue-300 mb-4">Making Tax Digital</span>
            <h2 class="text-3xl font-bold mb-4">MTD Is Coming.<br />Are You Ready?</h2>
            <p class="text-slate-300 leading-relaxed mb-6">
              From April 2026, landlords and self-employed people with income over £50,000 must submit quarterly updates to HMRC digitally. Our guides explain what you need to do and when.
            </p>
            <div class="space-y-3 mb-8">
              {[
                { date: 'April 2026', text: 'MTD for Income Tax starts (income over £50k)' },
                { date: 'April 2027', text: 'Threshold drops to £30,000' },
                { date: 'April 2028', text: 'Threshold drops to £20,000' },
              ].map((item) => (
                <div class="flex gap-4 items-start">
                  <div class="w-20 flex-shrink-0">
                    <span class="text-xs font-semibold bg-white/10 px-2 py-1 rounded">{item.date}</span>
                  </div>
                  <p class="text-sm text-slate-300">{item.text}</p>
                </div>
              ))}
            </div>
            <a href="/guides/making-tax-digital" class="inline-flex items-center bg-white text-slate-900 hover:bg-slate-100 px-4 py-2 rounded-lg text-sm font-medium transition-colors">
              Read the MTD Guide
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">Frequently Asked Questions</h2>
        <p class="text-slate-600">Quick answers to common questions. For more detail, read our guides.</p>
      </div>
      <FaqAccordion items={faqs} />
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 bg-sky-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Ready to Get Started?</h2>
      <p class="text-lg text-sky-100 leading-relaxed mb-10 max-w-2xl mx-auto">
        Download your first template in under a minute. No email required, no account to create. Or read our guides to learn the essentials first.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/templates" class="inline-flex items-center justify-center bg-white text-sky-700 hover:bg-sky-50 h-12 px-8 text-base font-semibold rounded-lg transition-colors">
          Browse All Templates
        </a>
