---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Bank Reconciliation Template UK — Free Excel Bank Rec for Small Business';
const description = 'Free UK bank reconciliation template for small businesses. Match bank transactions to your records and spot discrepancies. Works in Excel and Google Sheets.';
const canonical = '/bank-reconciliation-template-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Essential Bookkeeping
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Bank Reconciliation Template UK <span class="text-sky-700">(Free Download)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Free bank reconciliation template for UK small businesses. Match your bank statement to your records, spot errors, and find missing transactions. Simple and accurate.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Why Reconcile Your Bank?</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Bank reconciliation is the process of matching your bank statement to your own records. It catches errors, missing transactions, and fraud. Every business should do it monthly.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Without reconciliation, you might miss duplicate payments, uncleared cheques, or bank errors. You could also miss income that never hit your account.
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">What Our Template Does</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Transaction matching:</strong> Bank vs book records side by side</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Outstanding items:</strong> Transactions that haven't cleared</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Reconciliation check:</strong> Verifies bank balance matches books</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Error flagging:</strong> Highlights unmatched transactions</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Monthly summary:</strong> Running balance and variances</li>
          </ul>
        </div>
        <div class="bg-emerald-50 rounded-xl p-6 border border-emerald-200">
          <h3 class="font-bold text-emerald-900 mb-4">Get the Bank Reconciliation</h3>
          <p class="text-sm text-emerald-800 mb-4">Match your bank statement to your records. Spot errors and missing transactions.</p>
          <a href="/templates/bank-reconciliation" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Bank Reconciliation Template
          </a>
          <p class="text-xs text-emerald-600 text-center">Free. No email required.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Download Your Free Bank Reconciliation</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Keep your accounts accurate and catch every discrepancy.</p>
      <a href="/templates/bank-reconciliation" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Template
      </a>
    </div>
  </section>
</Layout>
