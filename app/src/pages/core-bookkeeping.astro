---
import Layout from '@/layouts/Layout.astro';
import TemplateIcon from '@/components/TemplateIcon.astro';
import { templates, categories } from '@/data/templates';
import { siteUrl } from '@/lib/utils';

const categoryId = 'core';
const category = categories.find(c => c.id === categoryId)!;
const categoryTemplates = templates.filter(t => t.category === categoryId);

const title = 'Free Bookkeeping Templates for UK Small Businesses | Open Sheets';
const description = 'Download free Excel bookkeeping templates: cash books, expense trackers, bank reconciliation, and budget forecasts. HMRC-aligned for UK sole traders and small businesses.';

const softwareAppSchemas = categoryTemplates.map((t) => ({
  '@type': 'SoftwareApplication',
  name: t.name,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Excel, Google Sheets, LibreOffice',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'GBP' },
  url: `${siteUrl}/templates/${t.id}`,
  description: t.description,
}));

const otherCategories = categories.filter(c => c.id !== 'all' && c.id !== categoryId);
---

<Layout title={title} description={description} jsonLd={softwareAppSchemas}>
  <!-- Breadcrumb -->
  <div class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex text-sm text-slate-500">
        <a href="/" class="hover:text-sky-700 transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-slate-900 font-medium">Core Bookkeeping</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-emerald-100 text-emerald-700 mb-4">Free Templates</span>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4 leading-tight">
        Core Bookkeeping <span class="text-sky-700">Templates</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-2xl mb-6">
        The foundation of every well-run business. Track transactions, reconcile your bank, manage expenses, and forecast your cash flow — all with free, HMRC-aligned Excel templates designed for UK sole traders and small businesses.
      </p>
      <div class="flex flex-wrap gap-3 text-sm text-slate-500">
        <span class="inline-flex items-center gap-1">
          <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {categoryTemplates.length} free templates
        </span>
        <span class="inline-flex items-center gap-1">
          <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          HMRC-aligned categories
        </span>
        <span class="inline-flex items-center gap-1">
          <svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          No signup required
        </span>
      </div>
    </div>
  </section>

  <!-- Template Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {categoryTemplates.map((template) => (
          <a
            href={`/templates/${template.id}`}
            class="group bg-slate-50 rounded-xl p-6 border border-slate-200 hover:border-sky-300 hover:shadow-md transition-all"
          >
            <div class={`w-12 h-12 rounded-xl ${template.color} flex items-center justify-center text-white mb-4`}>
              <TemplateIcon icon={template.icon} class="w-6 h-6" />
            </div>
            <h3 class="font-semibold text-slate-900 mb-2 group-hover:text-sky-700 transition-colors">{template.name}</h3>
            <p class="text-sm text-slate-600 mb-4 line-clamp-2">{template.description}</p>
            <ul class="space-y-1.5">
              {template.features.slice(0, 3).map((feature) => (
                <li class="flex items-start gap-2 text-xs text-slate-500">
                  <svg class="w-3.5 h-3.5 text-sky-700 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            <div class="mt-4 pt-4 border-t border-slate-200 flex items-center text-sm font-medium text-sky-700">
              View template
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Bookkeeping Matters -->
  <section class="py-16 bg-slate-50 border-y border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Why Good Bookkeeping Matters</h2>
          <p class="text-slate-600 mb-6">
            HMRC expects accurate records. Banks want to see clean financials. And you need to know if your business is actually making money. Good bookkeeping is not optional — it is the foundation everything else builds on.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sky-700 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-slate-600">Avoid HMRC penalties for poor record-keeping</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sky-700 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-slate-600">Know your true profit — not just your bank balance</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sky-700 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-slate-600">Be loan-ready with professional financial statements</span>
            </li>
          </ul>
        </div>
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-semibold text-slate-900 mb-4">What HMRC Requires</h3>
          <p class="text-sm text-slate-600 mb-4">
            HMRC requires you to keep records of all business income and expenses for at least 5 years. That includes:
          </p>
          <ul class="space-y-2 text-sm text-slate-600">
            <li class="flex items-start gap-2"><span class="text-sky-700 font-bold">•</span> All sales and income records</li>
            <li class="flex items-start gap-2"><span class="text-sky-700 font-bold">•</span> All business expenses with receipts</li>
            <li class="flex items-start gap-2"><span class="text-sky-700 font-bold">•</span> Bank and credit card statements</li>
            <li class="flex items-start gap-2"><span class="text-sky-700 font-bold">•</span> VAT records (if registered)</li>
            <li class="flex items-start gap-2"><span class="text-sky-700 font-bold">•</span> Payroll records (if you have staff)</li>
          </ul>
          <p class="text-xs text-slate-400 mt-4">Our templates make this easy — everything is pre-categorised and HMRC-aligned.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-sky-100 text-sky-700 mb-4">FAQ</span>
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Bookkeeping Template Questions</h2>
      </div>
      <div class="space-y-4">
        <details class="group bg-slate-50 rounded-lg border border-slate-200">
          <summary class="flex justify-between items-center cursor-pointer p-4 font-medium text-slate-900">
            Which bookkeeping template should I start with?
            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-sm text-slate-600">
            Most sole traders start with the <a href="/templates/cash-book" class="text-sky-700 hover:underline">Cash Book</a>. It is the simplest way to record all transactions and see your profit month by month. If you have more complex needs — like tracking assets and loans — use the <a href="/templates/cash-book-balance" class="text-sky-700 hover:underline">Cash Book with Balance Sheet</a>.
          </div>
        </details>
        <details class="group bg-slate-50 rounded-lg border border-slate-200">
          <summary class="flex justify-between items-center cursor-pointer p-4 font-medium text-slate-900">
            Do I need accounting software or will spreadsheets work?
            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-sm text-slate-600">
            For most small businesses and sole traders, spreadsheets are perfectly adequate. HMRC does not mandate software — they mandate accurate records. Our templates are designed to meet HMRC requirements without the cost and complexity of accounting software. As you grow, you may want to upgrade to software like Xero or QuickBooks.
          </div>
        </details>
        <details class="group bg-slate-50 rounded-lg border border-slate-200">
          <summary class="flex justify-between items-center cursor-pointer p-4 font-medium text-slate-900">
            How often should I update my bookkeeping records?
            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-4 pb-4 text-sm text-slate-600">
            Weekly is ideal — set aside 30 minutes every Friday to record the week\'s transactions. Monthly is the minimum. The more frequent, the easier it is. Waiting until year-end means reconstructing 12 months from memory and bank statements — a recipe for errors and missed deductions.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Related Categories -->
  <section class="py-16 bg-slate-50 border-y border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Explore Other Categories</h2>
        <p class="text-slate-600">More free templates for your business</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {otherCategories.map((cat) => (
          <a
            href={`/${cat.id === 'tax' ? 'tax-vat' : cat.id === 'reports' ? 'financial-reports' : cat.id === 'property' ? 'landlord-property' : cat.id === 'business' ? 'business-tools' : cat.id}`}
            class="group bg-white rounded-xl p-5 border border-slate-200 hover:border-sky-300 hover:shadow-md transition-all text-center"
          >
            <h3 class="font-semibold text-slate-900 group-hover:text-sky-700 transition-colors">{cat.label}</h3>
            <p class="text-xs text-slate-500 mt-1">
              {templates.filter(t => t.category === cat.id).length} templates
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-sky-700">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Ready to Get Your Books in Order?</h2>
      <p class="text-lg text-sky-100 mb-8">Download any of our free bookkeeping templates and start tracking your finances properly today.</p>
      <a href="/templates" class="inline-flex items-center justify-center bg-white text-sky-700 hover:bg-sky-50 h-14 px-8 text-base font-semibold rounded-lg transition-colors">
        Browse All Templates
      </a>
      <p class="text-sm text-sky-200 mt-6">Free downloads, no email required. Works in Excel and Google Sheets.</p>
    </div>
  </section>
</Layout>
