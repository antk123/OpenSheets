---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Balance Sheet Template UK — Free Small Business Balance Sheet';
const description = 'Free UK balance sheet template for small businesses and sole traders. Track assets, liabilities, and equity. Auto-calculating. No signup required.';
const canonical = '/balance-sheet-template-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Financial Reports
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Balance Sheet Template UK <span class="text-sky-700">(Free Download)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Free balance sheet template for UK small businesses. Track what you own, what you owe, and your net worth. Auto-calculating and HMRC-compatible.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">What Is a Balance Sheet?</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            A balance sheet shows your business's financial position at a single point in time. It answers one simple question: <strong>what is my business worth?</strong>
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            It has three parts: what you own (assets), what you owe (liabilities), and what's left over (equity). The golden rule: Assets = Liabilities + Equity.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            For sole traders, a balance sheet is not strictly required for Self Assessment. But it's incredibly useful for understanding your business health, applying for loans, or planning for growth.
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">What Our Template Includes</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Assets:</strong> Cash, equipment, stock, debtors</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Liabilities:</strong> Loans, creditors, overdrafts</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Equity:</strong> Capital, retained profit, drawings</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Auto-check:</strong> Verifies Assets = Liabilities + Equity</li>
          </ul>
        </div>
        <div class="bg-blue-50 rounded-xl p-6 border border-blue-200">
          <h3 class="font-bold text-blue-900 mb-4">Get the Balance Sheet Template</h3>
          <p class="text-sm text-blue-800 mb-4">Track your business's financial position. Auto-calculating and easy to use.</p>
          <a href="/templates/balance-sheet" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Balance Sheet Template
          </a>
          <p class="text-xs text-blue-600 text-center">Free. No email required.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">The Balance Sheet Equation</h2>
      <div class="bg-white rounded-xl border border-slate-200 p-8 text-center">
        <p class="text-2xl sm:text-3xl font-bold text-slate-900 mb-2">
          Assets = Liabilities + Equity
        </p>
        <p class="text-slate-600">Everything you own = Everything you owe + What's left over</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6 mt-8">
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-bold text-emerald-700 mb-2">Assets</h3>
          <p class="text-sm text-slate-600 mb-3">Things your business owns that have value.</p>
          <ul class="text-sm text-slate-600 space-y-1">
            <li>• Cash in bank</li>
            <li>• Equipment & tools</li>
            <li>• Stock/inventory</li>
            <li>• Money owed to you</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-bold text-red-700 mb-2">Liabilities</h3>
          <p class="text-sm text-slate-600 mb-3">Money your business owes to others.</p>
          <ul class="text-sm text-slate-600 space-y-1">
            <li>• Bank loans</li>
            <li>• Credit card debt</li>
            <li>• Money you owe suppliers</li>
            <li>• Tax owed to HMRC</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl p-6 border border-slate-200">
          <h3 class="font-bold text-sky-700 mb-2">Equity</h3>
          <p class="text-sm text-slate-600 mb-3">The owner's stake in the business.</p>
          <ul class="text-sm text-slate-600 space-y-1">
            <li>• Money you invested</li>
            <li>• Retained profit</li>
            <li>• Less: Drawings taken</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Download Your Free Balance Sheet</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Know what your business is worth. Track assets, liabilities, and equity in one place.</p>
      <a href="/templates/balance-sheet" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Template
      </a>
    </div>
  </section>
</Layout>
