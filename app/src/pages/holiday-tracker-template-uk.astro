---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Holiday Tracker Template UK — Free Excel Annual Leave Tracker for Small Business';
const description = 'Free UK holiday tracker template for small employers. Track annual leave, sick days, and remaining entitlement. Works in Excel and Google Sheets. No signup.';
const canonical = '/holiday-tracker-template-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-purple-100 text-purple-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Payroll
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Holiday Tracker Template UK <span class="text-sky-700">(Free Download)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Free annual leave tracker for UK small employers. Track holiday entitlement, days taken, and remaining balance for every employee. Legal and simple.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Why Track Holiday Entitlement?</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            UK law gives almost all workers 5.6 weeks of paid annual leave (28 days for full-time). Tracking this properly isn't just good practice — it's a legal requirement.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Our template tracks each employee's total entitlement, days taken, and remaining balance. It prevents disputes and ensures you never accidentally deny someone their legal right to time off.
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">What Our Template Includes</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-purple-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Annual entitlement:</strong> Total days per year</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-purple-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Days taken:</strong> Holiday booked and used</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-purple-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Remaining balance:</strong> Auto-calculated</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-purple-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Leave types:</strong> Annual, sick, maternity, etc.</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-purple-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Year-end rollover:</strong> Track carried-over days</li>
          </ul>
        </div>
        <div class="bg-purple-50 rounded-xl p-6 border border-purple-200">
          <h3 class="font-bold text-purple-900 mb-4">Get the Holiday Tracker</h3>
          <p class="text-sm text-purple-800 mb-4">Track annual leave for all employees. Stay compliant and avoid disputes.</p>
          <a href="/templates/holiday-tracker" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Holiday Tracker
          </a>
          <p class="text-xs text-purple-600 text-center">Free. No email required.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Download Your Free Holiday Tracker</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Track annual leave entitlement and stay on the right side of employment law.</p>
      <a href="/templates/holiday-tracker" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Template
      </a>
    </div>
  </section>
</Layout>
