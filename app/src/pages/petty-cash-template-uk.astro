---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Petty Cash Log Template UK — Free Excel Petty Cash Tracker';
const description = 'Free UK petty cash log template for small businesses. Track cash in, cash out, and running balance. Simple and accurate. Works in Excel and Google Sheets.';
const canonical = '/petty-cash-template-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Essential Bookkeeping
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Petty Cash Log Template UK <span class="text-sky-700">(Free Download)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Free petty cash log template for UK small businesses. Track every cash transaction, maintain a running balance, and stay audit-ready.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Why Track Petty Cash?</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Petty cash might be small amounts, but it adds up. £20 here, £15 there — over a year, that's hundreds of pounds. Without a log, you have no idea where it went.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            HMRC expects you to record every business expense, including petty cash. A proper log protects you in an audit and ensures you claim every penny you're entitled to.
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">What Our Template Includes</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Date and description:</strong> Every transaction recorded</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Receipt number:</strong> Link to physical receipt</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Running balance:</strong> Auto-calculated after each entry</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Expense category:</strong> HMRC-compliant categories</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Top-up tracking:</strong> Record when cash is replenished</li>
          </ul>
        </div>
        <div class="bg-emerald-50 rounded-xl p-6 border border-emerald-200">
          <h3 class="font-bold text-emerald-900 mb-4">Get the Petty Cash Log</h3>
          <p class="text-sm text-emerald-800 mb-4">Track every penny of petty cash. Stay organised and audit-ready.</p>
          <a href="/templates/petty-cash" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Petty Cash Log
          </a>
          <p class="text-xs text-emerald-600 text-center">Free. No email required.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Download Your Free Petty Cash Log</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Track every cash transaction and maintain a clear audit trail.</p>
      <a href="/templates/petty-cash" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Template
      </a>
    </div>
  </section>
</Layout>
