---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Expense Tracker Template UK — Free Business Expense Spreadsheet';
const description = 'Free UK business expense tracker template. Categorise expenses with HMRC-approved categories. Auto-totals for Self Assessment. No signup required.';
const canonical = '/expense-tracker-template-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Essential Bookkeeping
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Expense Tracker Template UK <span class="text-sky-700">(Free Download)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Track every business expense with HMRC-approved categories. Auto-totals for Self Assessment tax returns. Simple, fast, and free.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Why Expense Tracking Matters</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Every £1 of expenses you don't claim costs you 20-45p in extra tax. For a sole trader with £10,000 in unclaimed expenses, that's £2,000-£4,500 handed to HMRC unnecessarily.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            The problem isn't that people don't have expenses. It's that they don't track them. A receipt in a shoebox isn't a claim. You need a system — and a spreadsheet is the simplest system there is.
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">What Our Template Does</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Date, description, amount, and category for every expense</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>HMRC-approved expense categories built-in</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Auto-totals by category and month</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Self Assessment SA103 box mapping</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-emerald-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Receipt reference field for audit trail</li>
          </ul>
        </div>
        <div class="bg-emerald-50 rounded-xl p-6 border border-emerald-200">
          <h3 class="font-bold text-emerald-900 mb-4">Get the Expense Tracker</h3>
          <p class="text-sm text-emerald-800 mb-4">Stop overpaying tax. Track every expense and claim what you're entitled to.</p>
          <a href="/templates/expense-tracker" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Expense Tracker
          </a>
          <p class="text-xs text-emerald-600 text-center">Free. No email required.</p>
          <div class="mt-6 pt-6 border-t border-emerald-200">
            <h4 class="font-semibold text-emerald-900 text-sm mb-2">HMRC Expense Categories Included</h4>
            <div class="grid grid-cols-2 gap-1 text-xs text-emerald-800">
              <span>• Office costs</span>
              <span>• Travel</span>
              <span>• Clothing</span>
              <span>• Staff costs</span>
              <span>• Financial</span>
              <span>• Marketing</span>
              <span>• Training</span>
              <span>• Subscriptions</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-slate-900 mb-6">The 15-Minute Weekly Routine</h2>
      <div class="grid md:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl p-5 border border-slate-200 text-center">
          <div class="text-2xl mb-2">📸</div>
          <h3 class="font-semibold text-slate-900 text-sm mb-1">Snap Receipts</h3>
          <p class="text-xs text-slate-600">Photo every receipt same day</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-slate-200 text-center">
          <div class="text-2xl mb-2">📝</div>
          <h3 class="font-semibold text-slate-900 text-sm mb-1">Log Expenses</h3>
          <p class="text-xs text-slate-600">15 mins every Friday</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-slate-200 text-center">
          <div class="text-2xl mb-2">📊</div>
          <h3 class="font-semibold text-slate-900 text-sm mb-1">Check Totals</h3>
          <p class="text-xs text-slate-600">Review monthly summary</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-slate-200 text-center">
          <div class="text-2xl mb-2">✅</div>
          <h3 class="font-semibold text-slate-900 text-sm mb-1">Tax Ready</h3>
          <p class="text-xs text-slate-600">Figures ready for Self Assessment</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Download Your Free Expense Tracker</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Track every expense, claim every penny, and stop overpaying tax.</p>
      <a href="/templates/expense-tracker" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Template
      </a>
    </div>
  </section>
</Layout>
