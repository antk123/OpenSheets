---
import Layout from '@/layouts/Layout.astro';
import { siteUrl } from '@/lib/utils';

const title = 'Job Tracker Template UK — Free Excel Job Costing for Tradespeople';
const description = 'Free UK job tracker template for tradespeople and small businesses. Track job costs, time, materials, and profit per job. Works in Excel and Google Sheets.';
const canonical = '/job-tracker-template-uk';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: `${siteUrl}${canonical}`,
};
---

<Layout title={`${title} | Open Sheets`} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-12">
      <div class="inline-flex items-center gap-2 bg-indigo-100 text-indigo-700 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
        Operations
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mb-4">
        Job Tracker Template UK <span class="text-sky-700">(Free Download)</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl leading-relaxed">
        Free job tracker template for UK tradespeople and small businesses. Track costs, time, materials, and profit for every job. Know which jobs make money.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Know Which Jobs Make Money</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Not every job is profitable. Some customers cost more than they pay. A job tracker shows you the real profit on every piece of work — labour, materials, overheads, and margin.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Our template breaks down each job into costs and revenue, so you can see which types of work are worth pursuing and which customers to avoid.
          </p>
          <h3 class="text-lg font-semibold text-slate-900 mb-3">What Our Template Tracks</h3>
          <ul class="space-y-2 text-slate-600">
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Job details:</strong> Client, description, dates, status</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Labour costs:</strong> Hours worked × hourly rate</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Materials:</strong> Cost of goods used on the job</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Overheads:</strong> Fuel, parking, subcontractor costs</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Profit per job:</strong> Revenue minus all costs</li>
            <li class="flex items-start gap-2"><svg class="w-5 h-5 text-sky-700 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><strong>Margin %:</strong> Profit as percentage of revenue</li>
          </ul>
        </div>
        <div class="bg-indigo-50 rounded-xl p-6 border border-indigo-200">
          <h3 class="font-bold text-indigo-900 mb-4">Get the Job Tracker</h3>
          <p class="text-sm text-indigo-800 mb-4">Track costs, time, and profit for every job. Know which work makes money.</p>
          <a href="/templates/job-tracker" class="w-full inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white font-medium px-6 py-3 rounded-lg transition-colors mb-3">
            View Job Tracker
          </a>
          <p class="text-xs text-indigo-600 text-center">Free. No email required.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-sky-700">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Download Your Free Job Tracker</h2>
      <p class="text-sky-100 mb-8 max-w-2xl mx-auto">Track every job's costs and profit. Stop doing unprofitable work.</p>
      <a href="/templates/job-tracker" class="inline-flex items-center justify-center bg-white hover:bg-sky-50 text-sky-700 font-semibold px-8 py-3 rounded-lg transition-colors">
        Get the Template
      </a>
    </div>
  </section>
</Layout>
