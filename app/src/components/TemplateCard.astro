---
import TemplateIcon from './TemplateIcon.astro';
import type { SpreadsheetTemplate } from '@/data/templates';

export interface Props {
  template: SpreadsheetTemplate;
  showDetailsButton?: boolean;
}

const { template, showDetailsButton = true } = Astro.props;

const categoryColors: Record<string, string> = {
  core: 'bg-sky-100 text-sky-700',
  tax: 'bg-purple-100 text-purple-700',
  reports: 'bg-blue-100 text-blue-700',
  property: 'bg-amber-100 text-amber-700',
  business: 'bg-rose-100 text-rose-700',
};
---

<div class="group bg-white rounded-xl border border-slate-200 p-5 hover:shadow-lg hover:border-sky-200 transition-all duration-300 flex flex-col h-full">
  <div class="flex items-start justify-between mb-4">
    <div class={`w-12 h-12 rounded-xl ${template.color} bg-opacity-10 flex items-center justify-center`}>
      <div class={`${template.color} text-white rounded-xl p-2.5`}>
        <TemplateIcon icon={template.icon} />
      </div>
    </div>
    <div class="flex gap-1.5">
      {template.isNew && (
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-amber-100 text-amber-700">New</span>
      )}
      {template.isPopular && (
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-sky-100 text-sky-700">Popular</span>
      )}
    </div>
  </div>

  <h3 class="text-base font-semibold text-slate-900 mb-1.5 group-hover:text-sky-700 transition-colors">
    {template.name}
  </h3>
  <p class="text-sm text-slate-500 leading-relaxed mb-4 flex-1">
    {template.description}
  </p>

  <div class="flex items-center gap-2 mt-auto">
    <a
      href={`/templates/${template.fileName}`}
      download={template.fileName}
      class="flex-1 inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white text-sm font-medium px-3 py-2 rounded-md transition-colors"
    >
      <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
      </svg>
      Download
    </a>
    {showDetailsButton && (
      <a
        href={`/templates/${template.id}`}
        class="inline-flex items-center justify-center text-slate-600 border border-slate-200 hover:bg-slate-50 text-sm font-medium px-3 py-2 rounded-md transition-colors"
      >
        Details
      </a>
    )}
  </div>
</div>
