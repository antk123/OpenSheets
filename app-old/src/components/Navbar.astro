---
import { getCollection } from 'astro:content';
import MobileNav from './MobileNav.astro';

const guideCategories = [
  { id: 'bookkeeping', label: 'Bookkeeping' },
  { id: 'tax', label: 'Tax' },
  { id: 'mtd', label: 'Making Tax Digital' },
  { id: 'business', label: 'Business Setup' },
  { id: 'expenses', label: 'Expenses' },
];

const allGuides = await getCollection('guides');
const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-9 h-9 rounded-lg bg-sky-700 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="flex flex-col items-start">
          <span class="text-lg font-bold text-slate-900 leading-tight tracking-tight group-hover:text-sky-700 transition-colors">Open Sheets</span>
          <span class="text-[10px] font-medium text-sky-700 uppercase tracking-wider leading-none">UK Business Tools</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
        <a
          href="/"
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${isActive('/') ? 'bg-sky-100 text-sky-800' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}`}
        >
          Home
        </a>

        <!-- Guides Dropdown -->
        <div class="relative group">
          <button
            type="button"
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-all inline-flex items-center gap-1 ${pathname.startsWith('/guides') ? 'bg-sky-100 text-sky-800' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}`}
            aria-haspopup="true"
            aria-expanded="false"
          >
            Guides
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <div class="absolute top-full left-0 mt-1 w-80 bg-white rounded-xl shadow-xl border border-slate-200 py-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            <div class="px-4 py-2 border-b border-slate-100 mb-2">
              <a href="/guides" class="text-sm font-semibold text-slate-900 hover:text-sky-700 transition-colors">View All Guides</a>
            </div>
            {guideCategories.map((cat) => {
              const catGuides = allGuides.filter((g) => g.data.category === cat.id);
              if (catGuides.length === 0) return null;
              return (
                <div class="px-4 py-2" key={cat.id}>
                  <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">{cat.label}</span>
                  <div class="mt-1 space-y-0.5">
                    {catGuides.map((g) => (
                      <a
                        key={g.slug}
                        href={`/guides/${g.slug}`}
                        class="block text-sm text-slate-600 hover:text-sky-700 py-1 px-2 rounded-md hover:bg-slate-50 transition-all"
                      >
                        {g.data.title}
                      </a>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <a
          href="/templates"
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${isActive('/templates') ? 'bg-sky-100 text-sky-800' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}`}
        >
          Templates
        </a>
        <a
          href="/about"
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${isActive('/about') ? 'bg-sky-100 text-sky-800' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}`}
        >
          Why Spreadsheets?
        </a>
        <a
          href="/how-to-use"
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${isActive('/how-to-use') ? 'bg-sky-100 text-sky-800' : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'}`}
        >
          How to Use
        </a>

        <a
          href="/templates"
          class="ml-3 inline-flex items-center justify-center bg-sky-700 hover:bg-sky-800 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
        >
          Download Free Templates
        </a>
      </nav>

      <!-- Mobile Nav -->
      <MobileNav />
    </div>
  </div>
</header>
